<?xml version="1.0" encoding="utf-8"?>
<!--
  activity_main.xml — 다크 테마 '미니멀 키패드' 디자인.
  두 화면을 한 레이아웃에 담고 코드에서 보이기/숨기기로 전환:
   - dialerView : 평소(다이얼러)
   - inCallView : 통화 중(컨트롤 + 종료 버튼)
-->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg">

    <!-- ============================ 다이얼러 ============================ -->
    <LinearLayout
        android:id="@+id/dialerView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- 상단 우측 '최근 통화' 버튼 -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <ImageButton
                android:id="@+id/historyButton"
                android:layout_width="38dp"
                android:layout_height="38dp"
                android:layout_gravity="end"
                android:background="@drawable/bg_nav"
                android:src="@drawable/ic_history"
                android:scaleType="fitCenter"
                android:padding="9dp"
                android:contentDescription="최근 통화"
                app:tint="@color/textMuted"
                xmlns:app="http://schemas.android.com/apk/res-auto" />
        </FrameLayout>

        <!-- 헤더: 상태칩 + 서버 + 변경 버튼 -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="6dp"
            android:orientation="vertical"
            android:gravity="center_horizontal">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">
                <View
                    android:id="@+id/statusDot"
                    android:layout_width="7dp"
                    android:layout_height="7dp"
                    android:layout_marginEnd="7dp"
                    android:background="@drawable/dot" />
                <TextView
                    android:id="@+id/dchipText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="내선 103 · 등록 중"
                    android:textColor="@color/textMuted"
                    android:textSize="12.5sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <TextView
                android:id="@+id/serverText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="5dp"
                android:text="192.168.0.117:5060"
                android:textColor="@color/textTertiary"
                android:textSize="10.5sp" />

            <TextView
                android:id="@+id/changeNumberButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_pill"
                android:paddingHorizontal="17dp"
                android:paddingVertical="7dp"
                android:text="내선번호 변경"
                android:textColor="@color/accent"
                android:textSize="12.5sp"
                android:textStyle="bold"
                android:clickable="true"
                android:focusable="true" />
        </LinearLayout>

        <!-- 다이얼된 번호 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:orientation="vertical"
            android:gravity="center_horizontal">
            <TextView
                android:id="@+id/numval"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=""
                android:textColor="@color/textPrimary"
                android:textSize="40sp"
                android:fontFamily="sans-serif-medium" />
            <TextView
                android:id="@+id/numtgt"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="사무실 · 내선 통화"
                android:textColor="@color/textTertiary"
                android:textSize="11.5sp" />
        </LinearLayout>

        <!-- 아래로 밀기 -->
        <View
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <!-- 키패드 -->
        <GridLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:columnCount="3"
            android:layout_marginBottom="22dp">

            <TextView android:id="@+id/key1" style="@style/DialKey" android:text="1" />
            <TextView android:id="@+id/key2" style="@style/DialKey" android:text="2" />
            <TextView android:id="@+id/key3" style="@style/DialKey" android:text="3" />
            <TextView android:id="@+id/key4" style="@style/DialKey" android:text="4" />
            <TextView android:id="@+id/key5" style="@style/DialKey" android:text="5" />
            <TextView android:id="@+id/key6" style="@style/DialKey" android:text="6" />
            <TextView android:id="@+id/key7" style="@style/DialKey" android:text="7" />
            <TextView android:id="@+id/key8" style="@style/DialKey" android:text="8" />
            <TextView android:id="@+id/key9" style="@style/DialKey" android:text="9" />

            <!-- 빈 칸 (* 자리) -->
            <View
                android:layout_width="0dp"
                android:layout_height="50dp"
                android:layout_columnWeight="1"
                android:layout_gravity="fill_horizontal"
                android:layout_margin="5dp" />

            <TextView android:id="@+id/key0" style="@style/DialKey" android:text="0" />

            <!-- 삭제 (# 자리) -->
            <ImageView
                android:id="@+id/keyDel"
                android:layout_width="0dp"
                android:layout_height="50dp"
                android:layout_columnWeight="1"
                android:layout_gravity="fill_horizontal"
                android:layout_margin="5dp"
                android:src="@drawable/ic_backspace"
                android:scaleType="fitCenter"
                android:padding="13dp"
                android:contentDescription="삭제"
                android:clickable="true"
                android:focusable="true"
                app:tint="@color/textMuted"
                xmlns:app="http://schemas.android.com/apk/res-auto" />
        </GridLayout>

        <!-- 통화 버튼 -->
        <ImageView
            android:id="@+id/callButton"
            android:layout_width="66dp"
            android:layout_height="66dp"
            android:layout_gravity="center_horizontal"
            android:background="@drawable/bg_call_btn"
            android:src="@drawable/ic_call_fill"
            android:scaleType="fitCenter"
            android:padding="18dp"
            android:contentDescription="통화"
            android:clickable="true"
            android:focusable="true" />

    </LinearLayout>

    <!-- ============================ 통화 중 ============================ -->
    <LinearLayout
        android:id="@+id/inCallView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:padding="22dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/icStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="40dp"
            android:text="통화 중"
            android:textColor="@color/accent"
            android:textSize="13sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/icName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="내선 -"
            android:textColor="@color/textPrimary"
            android:textSize="30sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="사무실 인터폰"
            android:textColor="@color/textMuted"
            android:textSize="13.5sp" />

        <View
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <!-- 컨트롤 그리드 (음소거/키패드/스피커/돌려주기/녹음) -->
        <GridLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:columnCount="3"
            xmlns:app="http://schemas.android.com/apk/res-auto">

            <LinearLayout style="@style/CtlCell">
                <ImageView android:id="@+id/ctlMuteIcon" style="@style/CtlKey"
                    android:src="@drawable/ic_mic_off" app:tint="@color/textPrimary"
                    android:contentDescription="음소거" />
                <TextView style="@style/CtlLabel" android:text="음소거" />
            </LinearLayout>

            <LinearLayout style="@style/CtlCell">
                <ImageView android:id="@+id/ctlKeypadIcon" style="@style/CtlKey"
                    android:src="@drawable/ic_dialpad" app:tint="@color/textPrimary"
                    android:contentDescription="키패드" />
                <TextView style="@style/CtlLabel" android:text="키패드" />
            </LinearLayout>

            <LinearLayout style="@style/CtlCell">
                <ImageView android:id="@+id/ctlSpeakerIcon" style="@style/CtlKey"
                    android:src="@drawable/ic_volume_up" app:tint="@color/textPrimary"
                    android:contentDescription="스피커" />
                <TextView style="@style/CtlLabel" android:text="스피커" />
            </LinearLayout>

            <LinearLayout style="@style/CtlCell">
                <ImageView android:id="@+id/ctlTransferIcon" style="@style/CtlKey"
                    android:src="@drawable/ic_phone_forwarded" app:tint="@color/textPrimary"
                    android:contentDescription="돌려주기" />
                <TextView style="@style/CtlLabel" android:text="돌려주기" />
            </LinearLayout>

            <LinearLayout style="@style/CtlCell">
                <ImageView android:id="@+id/ctlRecordIcon" style="@style/CtlKey"
                    android:src="@drawable/ic_record" app:tint="@color/textPrimary"
                    android:contentDescription="녹음" />
                <TextView style="@style/CtlLabel" android:text="녹음" />
            </LinearLayout>
        </GridLayout>

        <!-- 종료 버튼 -->
        <ImageView
            android:id="@+id/endButton"
            android:layout_width="66dp"
            android:layout_height="66dp"
            android:layout_marginTop="54dp"
            android:layout_marginBottom="26dp"
            android:background="@drawable/bg_end_btn"
            android:src="@drawable/ic_call_end_fill"
            android:scaleType="fitCenter"
            android:padding="18dp"
            android:contentDescription="통화 종료"
            android:clickable="true"
            android:focusable="true" />

    </LinearLayout>

</FrameLayout>
