<?xml version="1.0" encoding="utf-8"?>
<!--
  activity_incoming.xml — 수신(전화 옴) 전체화면. 다크 디자인.
  (위) "수신 전화" / 발신자 / 펄스 원   …   (아래) 거절·수락 원형 버튼.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center_horizontal"
    android:background="@color/bg"
    android:paddingHorizontal="22dp"
    android:paddingTop="64dp"
    android:paddingBottom="40dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="수신 전화"
        android:textColor="@color/accent"
        android:textSize="13sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/callerText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="내선 -"
        android:textColor="@color/textPrimary"
        android:textSize="30sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:text="사무실 인터폰"
        android:textColor="@color/textMuted"
        android:textSize="13.5sp" />

    <!-- 펄스 원 -->
    <ImageView
        android:id="@+id/pulse"
        android:layout_width="96dp"
        android:layout_height="96dp"
        android:layout_marginTop="44dp"
        android:background="@drawable/bg_pulse"
        android:src="@drawable/ic_call_fill"
        android:scaleType="fitCenter"
        android:padding="28dp"
        android:contentDescription="수신"
        app:tint="@color/accent" />

    <!-- 아래로 밀기 -->
    <View
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <!-- 거절 / 수락 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:weightSum="2">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center_horizontal">
            <ImageView
                android:id="@+id/rejectButton"
                android:layout_width="68dp"
                android:layout_height="68dp"
                android:background="@drawable/bg_end_btn"
                android:src="@drawable/ic_call_end_fill"
                android:scaleType="fitCenter"
                android:padding="19dp"
                android:contentDescription="거절"
                android:clickable="true"
                android:focusable="true" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="거절"
                android:textColor="@color/textMuted"
                android:textSize="12.5sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center_horizontal">
            <ImageView
                android:id="@+id/acceptButton"
                android:layout_width="68dp"
                android:layout_height="68dp"
                android:background="@drawable/bg_call_btn"
                android:src="@drawable/ic_call_fill"
                android:scaleType="fitCenter"
                android:padding="19dp"
                android:contentDescription="수락"
                android:clickable="true"
                android:focusable="true" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="수락"
                android:textColor="@color/textMuted"
                android:textSize="12.5sp"
                android:textStyle="bold" />
        </LinearLayout>

    </LinearLayout>

</LinearLayout>
